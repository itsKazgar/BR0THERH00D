# ╔══════════════════════════════════════════════╗
# ║     BR0THERH00D — Environment Config         ║
# ╚══════════════════════════════════════════════╝
# Copy this file to .env and fill in your keys
# Only GROQ_API_KEY is needed to start — everything else is optional

# ── AI Brain (pick at least one) ──────────────
# Groq — free + fast, recommended to start: console.groq.com
GROQ_API_KEY=

# OpenRouter — access to many models, free tier available: openrouter.ai
OPENROUTER_API_KEY=

# Other providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
COHERE_API_KEY=
HF_API_KEY=
CEREBRAS_API_KEY=

# Cloudflare Workers AI (optional)
CF_ACCOUNT_ID=
CF_API_TOKEN=

# ── Solana Wallet ──────────────────────────────
# Required for live trading only — paper mode works without these
WALLET_ADDRESS=
WALLET_PRIVATE_KEY=

# ── Solana RPC ─────────────────────────────────
# Free tier: helius.dev or quicknode.com
# Leave blank to use public RPC (slower, rate-limited)
SOLANA_RPC=
HELIUS_API_KEY=

# ── Trading Mode ───────────────────────────────
TRADE_MODE=paper        # paper or live

# ── Telegram Alerts (optional) ─────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Loop Timing ────────────────────────────────
FAST_INTERVAL=60        # seconds between social/watchlist scans
FULL_INTERVAL=300       # seconds between full market scans

# ── Council Settings ───────────────────────────
MIN_AGENTS_TRADE=4      # how many agents must agree to trade (quorum)
MIN_TOKEN_AGE_HOURS=2   # reject tokens younger than this

# ── Trading Hours (optional) ───────────────────
# Leave both at 0/24 to trade 24/7 (default)
TRADING_HOUR_START=0
TRADING_HOUR_END=24

# ── Jupiter Settings ───────────────────────────
DEFAULT_SLIPPAGE_BPS=150    # 1.5% default slippage
MAX_SLIPPAGE_BPS=300        # 3% max slippage

# ── Dashboard ──────────────────────────────────
DASHBOARD_TOKEN=            # set a password for the dashboard
DASHBOARD_PUBLIC=false      # set true to allow public access
